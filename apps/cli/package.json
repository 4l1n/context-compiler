{
  "name": "@context-compiler/cli",
  "version": "0.1.0",
  "description": "Analyze, lint, and deterministically optimize LLM prompt/context files",
  "keywords": ["llm", "prompt", "context", "cli", "tokenizer", "lint"],
  "private": true,
  "type": "module",
  "engines": { "node": ">=18" },
  "files": ["dist"],
  "bin": {
    "ctxc": "./dist/ctxc.js",
    "context-compiler": "./dist/ctxc.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@context-compiler/config": "workspace:*",
    "@context-compiler/core": "workspace:*",
    "@context-compiler/rules": "workspace:*",
    "@context-compiler/tokenizers": "workspace:*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
